# Copy to .env and set your credentials:  cp .env.example .env

# Databricks Configuration (from SQL warehouse connection details)
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/YOUR_WAREHOUSE_ID
# Get your token: Databricks → Settings (user icon) → Developer → Access tokens → Generate new token
DATABRICKS_TOKEN=

# Supabase Configuration - AWS (us-west-2)
# Option 1: Individual Parameters (Recommended)
SUPABASE_DB_HOST=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres
SUPABASE_DB_PORT=6543

# Option 2: Connection String (AWS Pooler)
# SUPABASE_CONNECTION_STRING=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require

# Sync Configuration (optional)
OVERLAP_DAYS=7
FETCH_SIZE=5000

# Optional: default table when running connector.py as script
# DBX_TABLE=qas.aplicaciones.transportistas_final
# DBX_LIMIT=10

# Databricks source table for sync (catalog.schema.table). Required if not qas.club_transportistas.transportistas_final
# DBX_TABLE=your_catalog.your_schema.transportistas_final
